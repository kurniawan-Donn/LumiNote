<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog Konfirmasi Hapus Permanen -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/background_primary"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgIconDelete"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/img_hapus_permanen"
            android:contentDescription="@string/cd_delete_permanent_image"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvDeleteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_delete_permanent_dialog"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tvDeleteMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/msg_delete_permanent_dialog"
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancelDelete"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/btn_cancel"
                android:textStyle="bold"
                android:background="@color/text_secondary"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnConfirmDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.3"
                android:backgroundTint="@color/color_danger"
                android:text="@string/btn_delete"
                android:textColor="@color/background_primary"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
