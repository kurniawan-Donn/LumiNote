<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog Konfirmasi Hapus Tugas -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@color/background_primary"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/img_pulihkan_arsip"
            android:scaleType="centerInside"
            android:contentDescription="@string/cd_delete_task_image"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_delete_task_dialog"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_pesan_hapus_tugas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/msg_delete_task_dialog"
            android:textAlignment="center"
            android:layout_marginTop="8dp"
            android:textSize="16sp"
            android:textColor="@color/color_danger"
            android:alpha="0.7"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_batal_hapus_tugas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_cancel"
                android:textAllCaps="false"
                android:backgroundTint="@color/text_secondary"
                android:textColor="@color/background_primary"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btn_oke_hapus_tugas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/btn_delete"
                android:textAllCaps="false"
                android:backgroundTint="@color/color_danger"
                android:textColor="@color/white"
                app:cornerRadius="16dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
